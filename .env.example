# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024

# === App ===
APP_ENV=development
LOG_LEVEL=INFO

# === Database ===
POSTGRES_USER=draftwell
POSTGRES_PASSWORD=draftwell
POSTGRES_DB=draftwell
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://draftwell:draftwell@localhost:5432/draftwell
# Sync URL used by Alembic migrations (psycopg v3 driver)
DATABASE_URL_SYNC=postgresql+psycopg://draftwell:draftwell@localhost:5432/draftwell

# === CORS ===
# Comma-separated list of origins allowed to make cross-origin requests.
# Add your deployed frontend URL here (e.g. https://draftwell.vercel.app) without a code change.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Auth (we'll use this in Week 2) ===
# JWT_SECRET=change-me-to-a-long-random-string
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=60