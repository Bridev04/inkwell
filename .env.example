# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_DEFAULT_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024

# === App ===
# Set to "production" in Railway — enables Secure cookies, HSTS, and the
# JWT_SECRET_KEY strength validator. Never set to "production" locally.
ENVIRONMENT=development
# Never enable debug mode in production — exposes stack traces.
DEBUG=false
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# === Input limits ===
# Maximum characters accepted for each writing-tool endpoint (default 10 000).
# Increase only after profiling LLM latency and cost at the new limit.
FEEDBACK_MAX_TEXT_CHARS=10000
REWRITE_MAX_TEXT_CHARS=10000
GRAMMAR_MAX_TEXT_CHARS=10000
PARAPHRASE_MAX_TEXT_CHARS=10000

# === Database ===
POSTGRES_USER=draftwell
POSTGRES_PASSWORD=draftwell
POSTGRES_DB=draftwell
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://draftwell:draftwell@localhost:5432/draftwell
# Sync URL used by Alembic migrations (psycopg v3 driver)
DATABASE_URL_SYNC=postgresql+psycopg://draftwell:draftwell@localhost:5432/draftwell

# === CORS ===
# Comma-separated list of origins allowed to make cross-origin requests.
# In production: set to exactly your Vercel URL — no wildcards, no staging URLs.
# Example: CORS_ALLOWED_ORIGINS=https://draftwell.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Auth ===
# REQUIRED in production: must be ≥ 32 characters and not this placeholder.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Store ONLY in Railway's secret manager — never commit a real value.
JWT_SECRET_KEY=changeme-dev-only-not-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# === Google OAuth ===
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# OAuth Client ID type: Web application
# Authorized redirect URIs (local dev): http://localhost:3000/api/v1/auth/google/callback
# Authorized redirect URIs (prod):       https://yourdomain.com/api/v1/auth/google/callback
# Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_BASE_URL=http://localhost:3000
